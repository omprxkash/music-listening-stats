# Copy this to .env and fill in your own Spotify app credentials.
# You only need these if you want to connect a real Spotify account.
# The whole site runs without them in demo mode (npm run demo).

SPOTIFY_CLIENT_ID=your_client_id
SPOTIFY_CLIENT_SECRET=your_client_secret
SPOTIFY_REDIRECT_URI=http://localhost:3000/auth/callback
SESSION_SECRET=change_me_to_a_long_random_string
PORT=3000
